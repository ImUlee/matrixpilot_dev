# MatrixPilot 环境变量配置
# ⚠️ 请修改以下值为强密码，不要使用默认值！

# 应用PIN码 (用于登录管理后台) - 至少8位，包含数字和字母
APP_PIN=your_secure_pin_here

# Flask会话密钥 - 至少32位随机字符串
SECRET_KEY=your_random_secret_key_at_least_32_characters_long

# API密钥 - 用于客户端连接认证
API_KEY=your_api_key_here

# 时区设置
TZ=Asia/Shanghai

# Flask环境配置
FLASK_ENV=production
FLASK_DEBUG=0
